<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.obsidian-wiki.global</string>
  <key>ProgramArguments</key><array>
    <string>/bin/bash</string>
    <string>__HOME__/github/obsidian-wiki/scripts/wiki-global-job.sh</string>
  </array>
  <key>StartCalendarInterval</key><dict>
    <key>Hour</key><integer>9</integer><key>Minute</key><integer>30</integer>
  </dict>
  <key>StandardOutPath</key><string>/tmp/obsidian-wiki-global.log</string>
  <key>StandardErrorPath</key><string>/tmp/obsidian-wiki-global.err</string>
</dict></plist>
